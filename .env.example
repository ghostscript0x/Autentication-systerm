# ============================================================================
# Django Authentication System - Environment Configuration
# ============================================================================
#
# Copy this file to .env and adjust the values for your environment.
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# ============================================================================

# Django Secret Key
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me-in-production

# Debug Mode
# Set to True for development, False for production
DEBUG=True

# Allowed Hosts
# Comma-separated list of host/domain names this site can serve
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# Email Configuration (SMTP)
# ============================================================================
#
# For development, use the console backend (emails printed to console):
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# For production, use SMTP:
#   EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP Settings (used when EMAIL_BACKEND=smtp)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Default From Address
DEFAULT_FROM_EMAIL=noreply@example.com
